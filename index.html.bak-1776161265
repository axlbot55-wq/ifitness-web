/* CHATBOT */
#chat-fab{position:fixed;bottom:6rem;right:2rem;z-index:501;width:54px;height:54px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 24px rgba(200,168,75,.4);border:none;transition:all .3s;font-size:1.3rem}
#chat-fab:hover{transform:scale(1.1);box-shadow:0 6px 32px rgba(200,168,75,.55)}
#chat-fab .fab-close{display:none}
#chat-fab.open .fab-icon{display:none}
#chat-fab.open .fab-close{display:block}
#chat-fab.open{background:var(--card)}
#chatbox{position:fixed;bottom:9.5rem;right:2rem;z-index:500;width:350px;max-width:calc(100vw - 2rem);background:var(--card);border:1px solid rgba(200,168,75,.2);border-radius:var(--rl);overflow:hidden;box-shadow:0 16px 64px rgba(0,0,0,.7);transform:translateY(14px) scale(.97);opacity:0;pointer-events:none;transition:transform .28s ease,opacity .28s ease}
