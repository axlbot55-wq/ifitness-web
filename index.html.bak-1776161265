.cb-input:focus{border-color:rgba(200,168,75,.4)}
.cb-send{background:var(--accent);border:none;border-radius:var(--r);padding:0 .85rem;font-size:.95rem;cursor:pointer;transition:background .2s;color:var(--bg)}
.cb-send:hover{background:var(--accent-lt)}

/* MODALS */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;z-index:1000;padding:20px}
.modal-overlay.active{display:flex}
.modal-box{background:var(--card);padding:32px;border-radius:var(--rl);width:100%;max-width:480px;border:1px solid rgba(200,168,75,.2);box-shadow:0 16px 64px rgba(0,0,0,.7);position:relative;color:var(--white)}
.modal-close{position:absolute;top:16px;right:16px;background:transparent;border:none;color:var(--muted);font-size:1.5rem;cursor:pointer;padding:4px}
.modal-close:hover{color:var(--white)}
.modal-box h3{margin-bottom:16px;font-size:1.4rem;font-weight:800;color:var(--white)}
.modal-box p{color:var(--muted);margin-bottom:20px;font-size:.9rem;font-weight:300;line-height:1.6}
.hidden{display:none}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.reveal{opacity:0;transform:translateY(18px);transition:opacity .6s ease,transform .6s ease}.reveal.visible{opacity:1;transform:translateY(0)}
