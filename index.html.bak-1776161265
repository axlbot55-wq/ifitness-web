<script>
// Nav scroll
window.addEventListener('scroll',()=>{document.getElementById('mainNav').classList.toggle('scrolled',window.scrollY>50)});

// Mobile nav
function toggleMob(){const n=document.getElementById('mob-nav');n.style.display=n.style.display==='flex'?'none':'flex'}
function closeMob(){document.getElementById('mob-nav').style.display='none'}

// Prefill program from CTA buttons
function prefillForm(program){
  const sel=document.getElementById('programSelect');
  if(sel){
    for(let i=0;i<sel.options.length;i++){if(sel.options[i].text===program){sel.selectedIndex=i;break}}
  }
}

// Chat toggle
function toggleChat(){
  const fab=document.getElementById('chat-fab');
  const box=document.getElementById('chatbox');
  fab.classList.toggle('open');
  box.classList.toggle('open');
  document.getElementById('cbOptions').style.display='flex';
}

// Chat actions
function chatAction(type){
  const body=document.getElementById('cbBody');
  const opts=document.getElementById('cbOptions');
  let msg='';
  if(type==='whatsapp'){msg='Opening WhatsApp...';setTimeout(()=>{window.open('https://wa.me/639612071923','_blank')},500)}
  else if(type==='bmi'){msg='Let me open the BMI calculator...';setTimeout(()=>{openBmiModal();opts.style.display='none'},500)}
  else if(type==='plan'){msg='Let me get you that free plan...';setTimeout(()=>{openFreePlanModal();opts.style.display='none'},500)}
  else if(type==='book'){msg='Opening Calendly to book a session...';setTimeout(()=>{window.open('https://calendly.com/irishchumangit/30min','_blank')},500)}
  const userDiv=document.createElement('div');userDiv.className='cb-msg user-msg';
  const btnText={whatsapp:'Chat on WhatsApp',bmi:'BMI Assessment',plan:'Free 7-Day Plan',book:'Book a Session'};
  userDiv.textContent=btnText[type]||type;
  body.appendChild(userDiv);
  const botDiv=document.createElement('div');botDiv.className='cb-msg';botDiv.textContent=msg;
  body.appendChild(botDiv);
  body.scrollTop=body.scrollHeight;
}

function sendChatMsg(){
  const input=document.getElementById('cbInput');
  const msg=input.value.trim();if(!msg)return;
  const body=document.getElementById('cbBody');
  const userDiv=document.createElement('div');userDiv.className='cb-msg user-msg';userDiv.textContent=msg;
  body.appendChild(userDiv);
  input.value='';
  setTimeout(()=>{
    const botDiv=document.createElement('div');botDiv.className='cb-msg';botDiv.textContent="Thanks for your message! For faster response, chat with us on WhatsApp or book a session below. 💪";
    body.appendChild(botDiv);body.scrollTop=body.scrollHeight;
  },800);
}

// BMI Modal
function openBmiModal(){document.getElementById('bmiModal').classList.add('active')}
function closeBmiModal(){document.getElementById('bmiModal').classList.remove('active');document.getElementById('bmiFormDiv').classList.remove('hidden');document.getElementById('bmiResultDiv').classList.add('hidden')}
function calculateBmi(){
  const h=parseFloat(document.getElementById('bmiHeight').value);
  const w=parseFloat(document.getElementById('bmiWeight').value);
  if(!h||!w||h<100||w<20){alert('Please enter valid height and weight.');return}
  const bmi=(w/((h/100)**2)).toFixed(1);
  let cat='',range='';
  if(bmi<18.5){cat='Underweight';range='BMI < 18.5 — Consider a nutrition-focused program.'}
  else if(bmi<25){cat='Normal Weight';range='BMI 18.5–24.9 — Great! Maintain with regular training.'}
  else if(bmi<30){cat='Overweight';range='BMI 25–29.9 — A structured PT program can help.'}
  else{cat='Obese';range='BMI 30+ — Personal training with medical clearance recommended.'}
  document.getElementById('bmiVal').textContent=bmi;
  document.getElementById('bmiCategory').textContent=cat;
  document.getElementById('bmiRange').textContent=range;
  document.getElementById('bmiFormDiv').classList.add('hidden');
  document.getElementById('bmiResultDiv').classList.remove('hidden');
}

// Free Plan Modal
function openFreePlanModal(){document.getElementById('freePlanModal').classList.add('active')}
function closeFreePlanModal(){document.getElementById('freePlanModal').classList.remove('active');document.getElementById('freePlanEmailDiv').classList.remove('hidden');document.getElementById('freePlanResultDiv').classList.add('hidden')}
function submitFreePlan(){
  const email=document.getElementById('freePlanEmail').value;
  const dpa=document.getElementById('freePlanDpa').checked;
  if(!email||!dpa){alert('Please enter your email and accept the terms.');return}
  document.getElementById('freePlanEmailDiv').classList.add('hidden');
  document.getElementById('freePlanResultDiv').classList.remove('hidden');
}

// Reveal on scroll
const observer=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target)}})},{threshold:0.1});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
</script>
