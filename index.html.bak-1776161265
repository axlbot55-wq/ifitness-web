.cb-opt{background:var(--surface);border:1px solid rgba(200,168,75,.18);border-radius:var(--r);padding:.6rem .9rem;font-size:.72rem;font-weight:600;color:var(--text);cursor:pointer;transition:all .2s;text-align:left;display:flex;align-items:center;gap:.55rem;font-family:Inter,sans-serif}
.cb-opt:hover{border-color:var(--accent);color:var(--accent);background:rgba(200,168,75,.06)}
.cb-opt-icon{font-size:.95rem;flex-shrink:0}
.cb-input-row{display:flex;gap:.5rem;padding:0 1rem 1rem}
