.cb-head-info strong{display:block;font-size:.8rem;font-weight:700;color:var(--white)}
.cb-head-info span{font-size:.6rem;color:var(--muted);font-weight:400}
.cb-body{padding:1rem;max-height:320px;overflow-y:auto;display:flex;flex-direction:column;gap:.65rem}
.cb-msg{background:var(--surface);border-radius:4px 12px 12px 4px;padding:.72rem .95rem;font-size:.78rem;color:var(--text);line-height:1.6;font-weight:300;max-width:92%;white-space:pre-line}
.cb-msg.user-msg{background:rgba(200,168,75,.12);border:1px solid rgba(200,168,75,.18);border-radius:12px 4px 4px 12px;align-self:flex-end;color:var(--white)}
